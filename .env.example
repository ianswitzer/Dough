# ─────────────────────────────────────────────────────────────
# Dough environment variables — COPY this file to `.env` and fill in.
# `.env` is gitignored and must NEVER be committed.
#
# These two values are SAFE to ship in a client bundle. The Supabase
# "anon" key is a public, RLS-gated key by design — it only grants what
# your Row Level Security policies allow. Do NOT put the `service_role`
# key here or anywhere in the app; it bypasses RLS and is server-only.
# ─────────────────────────────────────────────────────────────

# Found in: Supabase Dashboard → Project Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co

# Found in: Supabase Dashboard → Project Settings → API → Project API keys → anon / public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
